#!/usr/bin/lua
-- Read stdin
local text = io.read("*a")
if not text or text == "" then
  io.write("Access-Control-Allow-Origin: *\r\nContent-Type: text/plain\r\n\r\nERROR: empty body")
  return
end

-- Read API key
local apikey = ""
local f = io.open("/mnt/sda1/picoclaw.sh", "r")
if f then
  for line in f:lines() do
    local k = line:match('PICOCLAW_MODEL_KEY="(.*)"')
    if k then apikey = k; break end
  end
  f:close()
end
if apikey == "" then
  io.write("Access-Control-Allow-Origin: *\r\nContent-Type: text/plain\r\n\r\nERROR: no api key")
  return
end

-- JSON-escape a string
local function esc(s)
  s = s:gsub("\\", "\\\\")
  s = s:gsub('"', '\\"')
  s = s:gsub("\r", "")
  s = s:gsub("\n", "\\n")
  s = s:gsub("\t", "\\t")
  return s
end

-- Build JSON body
local prompt = "将以下角色卡文本翻译为自然口语化的中文。保留所有格式、编号、标点符号。仅输出译文。"
local body = string.format(
  '{"model":"deepseek-chat","messages":[{"role":"system","content":"%s"},{"role":"user","content":"%s"}],"temperature":0.3,"max_tokens":4096}',
  esc(prompt), esc(text)
)

-- Write body to temp file (avoid shell quoting issues with -d @file)
local tmp = "/tmp/translate_lua.tmp"
local tf = io.open(tmp, "w")
tf:write(body)
tf:close()

-- Call DeepSeek API
local cmd = string.format(
  'curl -s --connect-timeout 30 --max-time 120 -H "Content-Type: application/json" -H "Authorization: Bearer %s" -d @%s https://api.deepseek.com/chat/completions 2>/dev/null',
  apikey, tmp
)
local pipe = io.popen(cmd)
local result = pipe:read("*a")
pipe:close()
os.remove(tmp)

if not result or result == "" then
  io.write("Access-Control-Allow-Origin: *\r\nContent-Type: text/plain\r\n\r\nERROR: timeout")
  return
end

-- Extract content field from JSON, properly handling \"
local start = result:find('"content":"')
if not start then
  io.write("Access-Control-Allow-Origin: *\r\nContent-Type: text/plain\r\n\r\nERROR: empty")
  return
end
start = start + 11
local parts = {}
local i = start
while i <= #result do
  local c = result:sub(i, i)
  if c == "\\" then
    table.insert(parts, c)
    i = i + 1
    if i <= #result then
      table.insert(parts, result:sub(i, i))
      i = i + 1
    end
  elseif c == '"' then
    break
  else
    table.insert(parts, c)
    i = i + 1
  end
end
local ct = table.concat(parts)

if ct == "" then
  io.write("Access-Control-Allow-Origin: *\r\nContent-Type: text/plain\r\n\r\nERROR: empty")
  return
end

io.write("Access-Control-Allow-Origin: *\r\nContent-Type: text/plain; charset=utf-8\r\n\r\n")
io.write(ct)
