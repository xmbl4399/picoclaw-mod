#!/bin/sh
TEXT=$(cat -)
if [ -z "$TEXT" ]; then
  printf "Access-Control-Allow-Origin: *\r\nContent-Type: text/plain\r\n\r\nERROR: empty body"
  exit 0
fi

API_KEY=""
if [ -f /mnt/sda1/picoclaw.sh ]; then
  API_KEY=$(grep PICOCLAW_MODEL_KEY= /mnt/sda1/picoclaw.sh | head -1)
  API_KEY="${API_KEY#*=}"
  API_KEY="${API_KEY%\"}"
  API_KEY="${API_KEY#\"}"
fi
if [ -z "$API_KEY" ]; then
  printf "Access-Control-Allow-Origin: *\r\nContent-Type: text/plain\r\n\r\nERROR: no api key"
  exit 0
fi

PROMPT="将以下角色卡文本翻译为自然口语化的中文。保留所有格式、编号、标点符号。仅输出译文。"

# JSON-escape: backslash, double-quote, newlines -> \n between lines
# BusyBox awk: use [\\] not \\ in regex; no trailing \n
T=$(printf "%s" "$TEXT" | awk '{gsub(/[\\]/,"\\\\"); gsub(/"/,"\\\""); if(NR>1) printf "\\\\n"; printf "%s",$0}' | tr -d '\r')

BODY="{\"model\":\"deepseek-chat\",\"messages\":[{\"role\":\"system\",\"content\":\"${PROMPT}\"},{\"role\":\"user\",\"content\":\"${T}\"}],\"temperature\":0.3,\"max_tokens\":4096}"

RESULT=$(curl -s --connect-timeout 30 --max-time 90 \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer ${API_KEY}" \
  -d "${BODY}" https://api.deepseek.com/chat/completions 2>/dev/null)

if [ -z "$RESULT" ]; then
  printf "Access-Control-Allow-Origin: *\r\nContent-Type: text/plain\r\n\r\nERROR: timeout"
  exit 0
fi

CT=$(echo "$RESULT" | awk -F'"content":"' '{print $2}' | awk -F'"' '{print $1}')
if [ -z "$CT" ]; then
  printf "Access-Control-Allow-Origin: *\r\nContent-Type: text/plain\r\n\r\nERROR: empty"
  exit 0
fi

printf "Access-Control-Allow-Origin: *\r\nContent-Type: text/plain; charset=utf-8\r\n\r\n"
printf "%s" "${CT}"
