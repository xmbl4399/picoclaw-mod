#!/bin/sh
TEXT=$(cat -)
if [ -z "$TEXT" ]; then
  printf 'Access-Control-Allow-Origin: *\r\nContent-Type: text/plain\r\n\r\nERROR: empty body'
  exit 0
fi

API_KEY=""
if [ -f /mnt/sda1/picoclaw.sh ]; then
  API_KEY=$(grep 'PICOCLAW_MODEL_KEY=' /mnt/sda1/picoclaw.sh 2>/dev/null | head -1)
  API_KEY=$(echo "$API_KEY" | sed 's/.*=//;s/ .*//')
fi
if [ -z "$API_KEY" ]; then
  printf 'Access-Control-Allow-Origin: *\r\nContent-Type: text/plain\r\n\r\nERROR: no api key'
  exit 0
fi

SYS_PROMPT='将以下角色卡文本翻译为自然口语化的中文。角色名音译。保留所有格式、编号、标点符号。仅输出译文。'
JSON_TEXT=$(echo "$TEXT" | sed 's/\\/\\\\/g; s/"/\\"/g' | tr -d '\r')
BODY=$(printf '{"model":"deepseek-chat","messages":[{"role":"system","content":"%s"},{"role":"user","content":"%s"}],"temperature":0.3,"max_tokens":4096}' "$SYS_PROMPT" "$JSON_TEXT")

RESULT=$(curl -s --connect-timeout 30 --max-time 90 -H "Content-Type: application/json" -H "Authorization: Bearer $API_KEY" -d "$BODY" https://api.deepseek.com/chat/completions 2>/dev/null)

if [ -z "$RESULT" ]; then
  printf 'Access-Control-Allow-Origin: *\r\nContent-Type: text/plain\r\n\r\nERROR: api timeout'
  exit 0
fi

CONTENT=$(echo "$RESULT" | sed 's/.*"content":"//;s/","refusal.*//;s/","role.*//;s/"//')

if [ -z "$CONTENT" ]; then
  printf 'Access-Control-Allow-Origin: *\r\nContent-Type: text/plain\r\n\r\nERROR: empty response'
  exit 0
fi

printf 'Access-Control-Allow-Origin: *\r\nContent-Type: text/plain; charset=utf-8\r\n\r\n'
printf '%s' "$CONTENT"
